    "/api/Ewaste/Recycle E_waste": {
      "post": {
        "tags": [
          "Ewaste"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Condition",
                  "Weight"
                ],
                "type": "object",
                "properties": {
                  "Condition": {
                    "type": "string"
                  },
                  "Description": {
                    "maxLength": 500,
                    "type": "string"
                  },
                  "Images": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  },
                  "Weight": {
                    "type": "number",
                    "format": "double"
                  },
                  "Address": {
                    "type": "string"
                  }
                }
              },
