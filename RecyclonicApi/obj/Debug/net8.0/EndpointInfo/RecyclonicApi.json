    "/api/MarketPlace/AddProductinMarketPlace": {
      "post": {
        "tags": [
          "MarketPlace"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Images",
                  "Name",
                  "Price"
                ],
                "type": "object",
                "properties": {
                  "Name": {
                    "maxLength": 255,
                    "minLength": 0,
                    "type": "string"
                  },
                  "Price": {
                    "minimum": 0.01,
                    "type": "number",
                    "format": "double"
                  },
                  "Description": {
                    "type": "string"
                  },
                  "Stock": {
                    "maximum": 2147483647,
                    "minimum": 0,
                    "type": "integer",
                    "format": "int32"
                  },
                  "Images": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary"
                    }
                  }
                }
              },
              "encoding": {
                "Name": {
                  "style": "form"
                },
                "Price": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "Stock": {
                  "style": "form"
